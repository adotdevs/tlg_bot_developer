NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://outreach:outreach@localhost:5432/outreach?schema=public
REDIS_URL=redis://localhost:6379
ADMIN_API_KEY=xjiwsnxjiwnxxijwnxijwnxeijwxn
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret
PUBLIC_WEBHOOK_BASE_URL=https://your-domain.example

# Optional: set webhook path prefix (full URL = PUBLIC_WEBHOOK_BASE_URL + path)
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rate limits & safety
MAX_MESSAGES_PER_MINUTE=10
DAILY_SEND_CAP=100
PER_LEAD_COOLDOWN_HOURS=24
MAX_LEAD_ATTEMPTS=2
FAILURE_RATE_THRESHOLD=0.35
CIRCUIT_WINDOW_SECONDS=300
TELEGRAM_ERROR_SPIKE_THRESHOLD=20

# Comma-separated consent values that may be enqueued (ConsentStatus enum values)
ALLOWED_CONSENT_STATUSES=GRANTED,EXPLICIT_OPT_IN

# Outreach template (deterministic structure; OpenAI only softens wording if enabled)
SENDER_NAME=Alex
SENDER_COMPANY=Your Company
OUTREACH_TEMPLATE=Hi {{name}}, this is {{sender_name}} from {{company}}. Just wanted to quickly check if you'd be open to a short call about something that might be relevant to you?

# Optional sales webhook on INTERESTED handoff
SALES_WEBHOOK_URL=

# Feature: use OpenAI to personalize template text (still bounded by backend rules)
USE_OPENAI_PERSONALIZATION=true
USE_OPENAI_CLASSIFICATION=true
